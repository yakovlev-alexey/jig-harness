DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jig_dev?schema=public"

# Test routes (E2E / integration against a test server — never enable in production)
# INCLUDE_TEST_ROUTES=true  # build-time: include test-server entry in dist (staging/E2E images only)
# ENABLE_TEST_ROUTES=true   # runtime: register /__test__/* routes (requires non-production NODE_ENV)
# TEST_ROUTES_TOKEN=        # required x-test-token header value for /__test__/* routes
TEST_ROUTES_TOKEN=
ENABLE_TEST_ROUTES=
INCLUDE_TEST_ROUTES=
