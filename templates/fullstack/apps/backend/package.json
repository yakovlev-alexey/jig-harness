{
  "name": "@app/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "build": "node scripts/build.mjs",
    "start": "NODE_ENV=production node dist/server.js",
    "start:test": "tsx src/test-server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@app/frontend": "workspace:*",
    "@app/types": "workspace:*",
    "@fastify/static": "catalog:",
    "@prisma/client": "catalog:",
    "fastify": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@jig-harness/eslint-config": "workspace:*",
    "@jig-harness/generators": "workspace:*",
    "@jig-harness/tsconfig": "workspace:*",
    "@turbo/gen": "^2.5.4",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prisma": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
