{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "ENABLE_TEST_ROUTES",
    "TEST_ROUTES_TOKEN",
    "INCLUDE_TEST_ROUTES",
    "E2E_BASE_URL",
    "E2E_API_URL",
    "SSR_API_ORIGIN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist/client/**", "dist/server/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
